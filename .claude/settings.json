{
    "permissions": {
        "allow": ["Read(**)", "Edit(**)", "Write(**)"],
        "deny": [
            "Read(**/.env*)",
            "Read(**/secrets/**)",
            "Read(**/*.pem)",
            "Read(**/*.key)",
            "Read(**/.aws/**)",
            "Read(**/.ssh/**)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$data = [Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $data.tool_input.file_path; if ($f) { npx prettier --write \"$f\" }",
                        "shell": "powershell"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "osascript -e 'display notification \"Claude needs you\" with title \"Claude Code\"'"
                    }
                ]
            }
        ]
    }
}
