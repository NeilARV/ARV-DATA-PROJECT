{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(npm *)", 
      "Bash(npx *)", 
      "Bash(node *)",
      "Bash(git *)", 
      "Bash(gh *)",
      "Bash(mkdir *)", 
      "Bash(mv *)", 
      "Bash(cp *)", 
      "Bash(touch *)",
      "Bash(bash .claude/skills/**)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Bash(git push *)", 
      "Bash(rm -rf *)",
      "Read(.env)", 
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\\\Users\\\\jcdos\\\\.claude\\\\skills\\\\impeccable\\\\scripts\\\\hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking UI changes"
          }
        ]
      }
    ]
  },
  "description": "Impeccable design detector: runs after Edit/Write/MultiEdit on UI files and surfaces findings as system reminders."
}
