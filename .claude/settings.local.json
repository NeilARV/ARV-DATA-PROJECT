{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(touch *)",
      "Bash(bash .claude/skills/**)",
      "PowerShell(npm *)",
      "PowerShell(npx *)",
      "PowerShell(node *)",
      "PowerShell(git *)",
      "PowerShell(gh *)",
      "PowerShell(New-Item *)",
      "PowerShell(Move-Item *)",
      "PowerShell(Copy-Item *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Select-String *)",
      "PowerShell(Set-Location *)",
      "PowerShell(Measure-Object *)",
      "Bash(npm run *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Blocked: rm -rf is not allowed' >&2; exit 2",
            "if": "Bash(rm -rf *)"
          },
          {
            "type": "command",
            "command": "echo 'Blocked: force push is not allowed' >&2; exit 2",
            "if": "Bash(git push --force*)"
          },
          {
            "type": "command",
            "command": "echo 'Blocked: force push is not allowed' >&2; exit 2",
            "if": "Bash(git push -f *)"
          },
          {
            "type": "command",
            "command": "echo 'Blocked: reading .env via shell is not allowed' >&2; exit 2",
            "if": "Bash(*.env*)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '## Git' && git branch --show-current && git status --short | head -10 && echo '' && git log --oneline -5"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && node_modules/.bin/prettier --write --ignore-unknown \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs you\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if ! npm run check > /tmp/claude_tsc.log 2>&1; then echo 'Type check (npm run check) failed — fix before finishing:'; tail -40 /tmp/claude_tsc.log; exit 2; fi"
          }
        ]
      }
    ]
  }
}
