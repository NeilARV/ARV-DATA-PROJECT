<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>New Deals Available</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f7f9; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; margin:40px 0; border-radius:6px; overflow:hidden;">

            <!-- Header -->
            <tr>
              <td style="background-color:#69C9E1; padding:24px; text-align:center;">
                <h1 style="margin:0; color:#ffffff; font-size:22px;">
                  New Deal Available
                </h1>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:32px 24px; text-align:center; color:#333333;">
                <p style="margin:0; font-size:18px; line-height:1.6;">
                  A new deal has been added in <strong>{{county}}</strong>.
                </p>
              </td>
            </tr>

            <!-- CTA Button -->
            <tr>
              <td align="center" style="padding:8px 24px 40px;">
                <a href="{{cta_url}}" style="background-color:#69C9E1; color:#ffffff; text-decoration:none; padding:14px 32px; border-radius:4px; font-size:16px; font-weight:bold; display:inline-block;">
                  View Deals
                </a>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:16px; text-align:center; color:#999; font-size:12px; border-top:1px solid #eeeeee;">
                You're receiving this email because you subscribed to deal alerts.<br />
                © {{year}} {{company_name}}
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>