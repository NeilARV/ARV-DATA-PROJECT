<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>New Deal Available</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f7f9; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; margin:40px 0; border-radius:6px; overflow:hidden;">

            <!-- Header -->
            <tr>
              <td style="background-color:#69C9E1; padding:24px; text-align:center;">
                <h1 style="margin:0; color:#ffffff; font-size:22px;">
                  New Deal Available
                </h1>
              </td>
            </tr>

            <!-- Intro -->
            <tr>
              <td style="padding:24px 24px 16px; color:#333333; text-align:center;">
                <p style="margin:0; font-size:16px; line-height:1.5;">
                  A new deal has been added in <strong>{{county}}</strong>.
                </p>
              </td>
            </tr>

            <!-- Deal Card -->
            <tr>
              <td style="padding:0 24px 24px;">
                <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #e6e6e6; border-radius:6px; overflow:hidden;">
                  <tr>

                    <!-- Left: Image column -->
                    <td width="200" valign="top" style="width:200px; min-width:200px; vertical-align:top;">

                      {{#image_block}}
                      <!-- Street view image with badge overlay -->
                      <!--[if gte mso 9]>
                      <v:image xmlns:v="urn:schemas-microsoft-com:vml" fill="true" stroke="false" style="border:0;display:inline-block;width:200px;height:200px;" src="{{url}}" />
                      <v:rect xmlns:v="urn:schemas-microsoft-com:vml" fill="true" stroke="false" style="border:0;display:inline-block;width:200px;height:200px;">
                      <v:fill opacity="0%" color="#000000" />
                      <v:textbox inset="0,0,0,0">
                      <![endif]-->
                      <table width="200" cellpadding="0" cellspacing="0" style="background-image:url('{{url}}'); background-size:cover; background-position:center center; width:200px;" role="presentation">
                        <tr>
                          <td height="200" valign="top" style="padding:10px;">
                            <span style="display:inline-block; background-color:{{deal_type_color}}; color:#ffffff; font-family:Arial, Helvetica, sans-serif; font-size:11px; font-weight:700; padding:4px 8px; border-radius:4px; white-space:nowrap;">
                              {{deal_type_label}}
                            </span>
                          </td>
                        </tr>
                      </table>
                      <!--[if gte mso 9]>
                      </v:textbox>
                      </v:rect>
                      <![endif]-->
                      {{/image_block}}

                      {{#no_image_block}}
                      <!-- Placeholder when no image -->
                      <table width="200" cellpadding="0" cellspacing="0" style="background-color:#e8edf0; width:200px;" role="presentation">
                        <tr>
                          <td height="200" valign="top" style="padding:10px;">
                            <span style="display:inline-block; background-color:{{deal_type_color}}; color:#ffffff; font-family:Arial, Helvetica, sans-serif; font-size:11px; font-weight:700; padding:4px 8px; border-radius:4px; white-space:nowrap;">
                              {{deal_type_label}}
                            </span>
                          </td>
                        </tr>
                      </table>
                      {{/no_image_block}}

                    </td>

                    <!-- Right: Property details -->
                    <td valign="top" style="padding:16px 18px; vertical-align:top;">

                      <!-- Address -->
                      <p style="margin:0; font-size:15px; font-weight:700; color:#1a1a1a; line-height:1.3;">
                        {{address}}
                      </p>
                      <p style="margin:3px 0 0; font-size:13px; color:#777777;">
                        {{city}}, {{state}} {{zipcode}}
                      </p>

                      <!-- Beds / Baths / Sqft -->
                      {{#specs_line}}
                      <p style="margin:12px 0 0; font-size:13px; color:#333333;">{{.}}</p>
                      {{/specs_line}}

                      <!-- Property Type -->
                      {{#property_type}}
                      <p style="margin:4px 0 0; font-size:13px; color:#999999;">{{.}}</p>
                      {{/property_type}}

                      <!-- Price + Potential ARV (same row) -->
                      <table cellpadding="0" cellspacing="0" style="margin-top:12px;">
                        <tr valign="top">
                          {{#price}}
                          <td style="padding-right:20px;">
                            <p style="margin:0; font-size:11px; font-weight:600; color:#999999; text-transform:uppercase; letter-spacing:0.5px;">Price</p>
                            <p style="margin:2px 0 0; font-size:20px; font-weight:700; color:#1a1a1a;">${{.}}</p>
                          </td>
                          {{/price}}
                          {{#potential_arv}}
                          <td>
                            <p style="margin:0; font-size:11px; font-weight:600; color:#999999; text-transform:uppercase; letter-spacing:0.5px;">Potential ARV</p>
                            <p style="margin:2px 0 0; font-size:20px; font-weight:700; color:#2e7d32;">${{.}}</p>
                          </td>
                          {{/potential_arv}}
                        </tr>
                      </table>

                      <!-- Posted date -->
                      <p style="margin:12px 0 0; font-size:12px; color:#aaaaaa;">
                        {{posted_at}}
                      </p>

                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Notes -->
            {{#notes}}
            <tr>
              <td style="padding:0 24px 24px;">
                <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f9fa; border-left:3px solid #69C9E1; border-radius:0 4px 4px 0;">
                  <tr>
                    <td style="padding:12px 16px;">
                      <p style="margin:0 0 4px; font-size:11px; font-weight:600; color:#999999; text-transform:uppercase; letter-spacing:0.5px;">Notes</p>
                      <p style="margin:0; font-size:14px; color:#333333; line-height:1.5;">{{.}}</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {{/notes}}

            <!-- CTA Button -->
            <tr>
              <td align="center" style="padding:8px 24px 40px;">
                <a href="{{cta_url}}" style="background-color:#69C9E1; color:#ffffff; text-decoration:none; padding:14px 32px; border-radius:4px; font-size:16px; font-weight:bold; display:inline-block;">
                  View Deals
                </a>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:16px; text-align:center; color:#999; font-size:12px; border-top:1px solid #eeeeee;">
                You're receiving this email because you subscribed to deal alerts.<br />
                © {{year}} {{company_name}}
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
