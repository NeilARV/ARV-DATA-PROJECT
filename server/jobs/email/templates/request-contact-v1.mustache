<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Info Request</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f7f9; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; margin:40px 0; border-radius:6px; overflow:hidden;">

            <!-- Header -->
            <tr>
              <td style="background-color:#69C9E1; padding:24px; text-align:center;">
                <h1 style="margin:0; color:#ffffff; font-size:22px;">
                  New Info Request
                </h1>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:32px 24px; color:#333333; font-size:16px; line-height:1.6;">
                <p style="margin:0 0 16px;">
                  <strong>{{firstName}} {{lastName}}</strong> is requesting info for:
                </p>
                <p style="margin:0 0 16px; font-size:18px; font-weight:600; color:#222;">
                  {{address}}
                </p>
                <p style="margin:0;">
                  Reply to them at
                  <a href="mailto:{{email}}" style="color:#69C9E1; text-decoration:none;">{{email}}</a>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:16px; text-align:center; color:#999; font-size:12px; border-top:1px solid #eeeeee;">
                Internal notification — no action needed if already handled.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>