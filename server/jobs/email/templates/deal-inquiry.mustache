<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Deal Interest</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f7f9; font-family: Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="650" cellpadding="0" cellspacing="0" style="background-color:#ffffff; margin:40px 0; border-radius:6px; overflow:hidden;">

            <!-- Header -->
            <tr>
              <td style="background-color:#69C9E1; padding:24px; text-align:center;">
                <h1 style="margin:0; color:#ffffff; font-size:22px;">Deal Interest</h1>
              </td>
            </tr>

            <!-- Intro -->
            <tr>
              <td style="padding:28px 32px 20px; color:#333333; text-align:center;">
                <p style="margin:0; font-size:16px; line-height:1.6;">
                  <strong>{{requesterName}}</strong> has requested more information about your deal at <strong>{{address}}</strong>.
                </p>
              </td>
            </tr>

            <!-- Requester Contact Card -->
            <tr>
              <td style="padding:0 32px 24px;">
                <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #e6e6e6; border-radius:6px; overflow:hidden;">
                  <tr>
                    <td style="padding:18px 20px;">
                      <p style="margin:0 0 14px; font-size:11px; font-weight:600; color:#999999; text-transform:uppercase; letter-spacing:0.5px;">Requester Contact</p>
                      <table cellpadding="0" cellspacing="0" style="font-size:14px; width:100%;">
                        {{#requesterName}}
                        <tr>
                          <td style="padding:4px 16px 4px 0; color:#999999; white-space:nowrap; vertical-align:top; width:60px;"><strong>Name</strong></td>
                          <td style="padding:4px 0; color:#1a1a1a;">{{requesterName}}</td>
                        </tr>
                        {{/requesterName}}
                        <tr>
                          <td style="padding:4px 16px 4px 0; color:#999999; white-space:nowrap; vertical-align:top; width:60px;"><strong>Email</strong></td>
                          <td style="padding:4px 0; color:#1a1a1a;">
                            <a href="mailto:{{requesterEmail}}" style="color:#69C9E1; text-decoration:none;">{{requesterEmail}}</a>
                          </td>
                        </tr>
                        {{#requesterPhone}}
                        <tr>
                          <td style="padding:4px 16px 4px 0; color:#999999; white-space:nowrap; vertical-align:top; width:60px;"><strong>Phone</strong></td>
                          <td style="padding:4px 0; color:#1a1a1a;">{{requesterPhone}}</td>
                        </tr>
                        {{/requesterPhone}}
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Message (optional) -->
            {{#message}}
            <tr>
              <td style="padding:0 32px 24px;">
                <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f9fa; border-left:3px solid #69C9E1; border-radius:0 4px 4px 0;">
                  <tr>
                    <td style="padding:12px 16px;">
                      <p style="margin:0 0 4px; font-size:11px; font-weight:600; color:#999999; text-transform:uppercase; letter-spacing:0.5px;">Message</p>
                      <p style="margin:0; font-size:14px; color:#333333; line-height:1.5;">{{message}}</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {{/message}}

            <!-- CTA Button -->
            <tr>
              <td align="center" style="padding:8px 32px 28px;">
                <a href="{{dealUrl}}" style="background-color:#69C9E1; color:#ffffff; text-decoration:none; padding:14px 32px; border-radius:4px; font-size:16px; font-weight:bold; display:inline-block;">
                  View Deal
                </a>
              </td>
            </tr>

            <!-- Reply note -->
            <tr>
              <td style="padding:0 32px 32px; text-align:center;">
                <p style="margin:0; font-size:13px; color:#999999;">Reply to this email to respond directly to {{requesterName}}.</p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:16px; text-align:center; color:#999; font-size:12px; border-top:1px solid #eeeeee;">
                You're receiving this email because someone inquired about your deal.<br />
                &#169; {{year}} {{companyName}}
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
